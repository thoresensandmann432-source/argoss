# ARGOS UNIVERSAL OS — synchronized .env example
# Copy to `.env` and fill only the providers and modules you want enabled.

# ===== TELEGRAM =====
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789
USER_IDS=
BOT_IDS=
ARC_API_KEY=fe4056e5-a796-41be-be29-419d9822f625
# ===== VOICE =====
TG_VOICE_REPLY=off
TG_VOICE_ENGINE=gtts
TG_VOICE_LANG=ru
ARGOS_VOICE_DEFAULT=off
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ===== AI PROVIDERS =====
ARGOS_AI_MODE=auto

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

GROQ_API_KEY=
GROQ_MODEL=

DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

KIMI_API_KEY=
KIMI_MODEL=
ARGOS_KIMI_TOOLS=1

HUGGINGFACE_TOKEN=
HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_MODEL_SPACE=
HUGGINGFACE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_LOCAL_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
HF_TXT2IMG_MODEL=stabilityai/sdxl-turbo
HF_IMAGE_SPACES=black-forest-labs/FLUX.2-dev,mrfakename/Z-Image-Turbo,Tongyi-MAI/Z-Image-Turbo,dwzhu/PaperBanana,Asahina2K/animagine-xl-4.0,IbarakiDouji/FurryToonMix
HF_IMAGE_PROMPT_SPACE=NetNarco/Image-prompt-generator
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=

ARGOS_DISABLE_GEMINI=0
ARGOS_DISABLE_GIGACHAT=0
ARGOS_DISABLE_KIMI=0
ARGOS_DISABLE_GRIST=0
ARGOS_ENABLE_IOT=1

# ===== GIGACHAT =====
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
GIGACHAT_ACCESS_TOKEN=
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_INSECURE=1

# ===== IBM / WATSON =====
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_CHANNEL=ibm_quantum_platform
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# ===== OLLAMA / GPU ROUTING =====
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_FAST_MODEL=tinyllama:latest
OLLAMA_CLOUD_MODEL=llama3:latest
OLLAMA_TIMEOUT=150
OLLAMA_TIMEOUT_FAST=30
OLLAMA_TIMEOUT_SMART=120
OLLAMA_TIMEOUT_CLOUD=180
OLLAMA_GPU_LAYERS=-1
OLLAMA_MAIN_GPU=0
OLLAMA_REFLEX_HOST=http://localhost:11435
OLLAMA_REFLEX_MODEL=phi3:mini
OLLAMA_REFLEX_GPU=1
OLLAMA_VEGA_HOST=http://localhost:11436
OLLAMA_VEGA_MODEL=tinyllama
ARGOS_GPU_VEGA11=2
NEURAL_SWARM_BRAIN_GPU=0
NEURAL_SWARM_REFLEX_GPU=1

# ===== MEMORY / VECTOR STORE =====
ARGOS_VECTOR_WARMUP_MODE=async
ARGOS_WARMUP_FACT_LIMIT=120
ARGOS_WARMUP_NOTE_LIMIT=60

# ===== SYSTEM / BEHAVIOUR =====
ARGOS_ROLE=admin
ARGOS_LOG_LEVEL=INFO
ARGOS_PROVIDER_FAILURE_COOLDOWN=300
ARGOS_PROVIDER_COOLDOWN=60
ARGOS_AUTO_COLLAB=off
ARGOS_AUTO_COLLAB_MAX_MODELS=3
ARGOS_CONSENSUS_MODE=on
ARGOS_CONSENSUS_N=3
ARGOS_PRIMARY_CLOUD=gemini
ARGOS_HOMEOSTASIS=on
ARGOS_HOMEOSTASIS_INTERVAL=8
ARGOS_CURIOSITY=on
ARGOS_TASK_WORKERS=2

# ===== P2P / REDIS BUS =====
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_CHANNEL_PREFIX=argos
ARGOS_TASK_RPS_SYSTEM=8
ARGOS_TASK_RPS_IOT=6
ARGOS_TASK_RPS_AI=3
ARGOS_TASK_RPS_HEAVY=1
ARGOS_REMOTE_TOKEN=CHANGE_ME

# ===== WINDOWS BRIDGE =====
ARGOS_WIN_BRIDGE=on
ARGOS_WIN_BRIDGE_URL=http://localhost:5000/exec
ARGOS_WIN_BRIDGE_PORT=5000
ARGOS_BRIDGE_TOKEN=Generation_2026

# ===== EMAIL / SMTP =====
SMTP_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Optional legacy email bridge aliases
ARGOS_EMAIL_USERNAME=
ARGOS_EMAIL_PASSWORD=
ARGOS_EMAIL_SMTP_HOST=
ARGOS_EMAIL_SMTP_PORT=
ARGOS_EMAIL_IMAP_HOST=

# ===== NETWORK / MQTT =====
MQTT_HOST=localhost
MQTT_PORT=1883

# ===== HOME ASSISTANT =====
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# ===== OPEN DATA / GEO / WEATHER =====
OPENWEATHER_API_KEY=
OPENCAGE_API_KEY=
IPSTACK_API_KEY=
ABSTRACTAPI_KEY=
WORLD_BANK_API_KEY=
UN_DATA_API_KEY=
OECD_API_KEY=
CENSUS_API_KEY=
OPENDATASOFT_API_KEY=
NYC_OPENDATA_APP_TOKEN=

# ===== COMMS / NOTIFICATIONS =====
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
SENDGRID_API_KEY=

# ===== BUSINESS / LINKS / DOCS =====
CLEARBIT_API_KEY=
BITLY_TOKEN=
PDFCO_API_KEY=

# ===== SCRAPING / AUTOMATION =====
APIFY_TOKEN=

# ===== CONTENT FETCHER / WHITELIST =====
# safe = только разрешённые домены, free = без whitelist-ограничений
CONTENT_ALLOW_ALL=0
CONTENT_API_PORT=5050
ALLOWED_DOMAINS=unsplash.com,images.unsplash.com,api.unsplash.com,pexels.com,images.pexels.com,openverse.engineering,commons.wikimedia.org,freemusicarchive.org,jamendo.com,raw.githubusercontent.com,githubusercontent.com,gutenberg.org,samplefiles.org,picsum.photos,loremflickr.com

# ===== FIRMWARE / COLIBRI BUILD =====
FIRMWARE_ESP32_ENV=esp32dev
FIRMWARE_ESP8266_FQBN=esp8266:esp8266:nodemcuv2
FIRMWARE_UPLOAD_PORT=
COLIBRI_COMMIT=a7706a062a449ae56751ac980603b9ead

# ===== OPTIONAL REDIS URL (for Upstash/cloud) =====
REDIS_URL=
