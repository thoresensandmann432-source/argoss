# ╔══════════════════════════════════════════════════════════════╗
# ║           ARGOS UNIVERSAL OS — .env.example                 ║
# ║  Скопируй в .env и заполни нужные значения                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ──────────────────────────────────────────────────────────────
# 🤖 TELEGRAM
# ──────────────────────────────────────────────────────────────

# Токен бота (обязательно) — получи у @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# ID администраторов через запятую (обязательно минимум 1)
# Узнать свой ID: написать @userinfobot
ADMIN_IDS=123456789

# ID обычных пользователей через запятую (необязательно)
# Имеют доступ к чату и базовым командам, но не к терминалу/файлам
USER_IDS=987654321,111222333

# ID авторизованных ботов через запятую (необязательно)
# Боты из этого списка могут писать Аргосу и получать ответы
BOT_IDS=444555666,777888999

# ──────────────────────────────────────────────────────────────
# 🔊 ГОЛОСОВОЙ ОТВЕТ В TELEGRAM
# ──────────────────────────────────────────────────────────────

# Отвечать голосом (on/off)
TG_VOICE_REPLY=off

# Движок синтеза речи: gtts (онлайн, нужен интернет) / pyttsx3 (офлайн)
TG_VOICE_ENGINE=gtts

# Язык для gTTS (ru, en, de, fr, ...)
TG_VOICE_LANG=ru

# ──────────────────────────────────────────────────────────────
# 👁 VISION / ЗРЕНИЕ
# ──────────────────────────────────────────────────────────────

# Модель Ollama для анализа изображений (LLaVA)
# Установить: ollama pull llava
OLLAMA_VISION_MODEL=llava

# ──────────────────────────────────────────────────────────────
# 🤖 AI ПРОВАЙДЕРЫ
# ──────────────────────────────────────────────────────────────

# Режим ИИ: auto / gemini / ollama / gigachat / yandexgpt / groq / deepseek / openai
ARGOS_AI_MODE=auto

# Google Gemini (бесплатно: 1500 запросов/день)
# Получить: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here
# Модель (опционально, auto-resolve если не задано)
# GEMINI_MODEL=gemini-2.0-flash

# Groq — Llama 3.1 70B, очень быстро, бесплатно
# Получить: https://console.groq.com
GROQ_API_KEY=your_key_here
# GROQ_MODEL=llama3-70b-8192

# DeepSeek — мощная модель, дёшево
# Получить: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_key_here
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_API_KEY=your_key_here
# OPENAI_MODEL=gpt-4o-mini

# GigaChat (Сбер) — только из РФ
GIGACHAT_CLIENT_ID=your_client_id
GIGACHAT_CLIENT_SECRET=your_client_secret
# GIGACHAT_ACCESS_TOKEN=your_access_token  # альтернативно
GIGACHAT_MODEL=GigaChat-2
GIGACHAT_INSECURE=1

# YandexGPT
YANDEX_IAM_TOKEN=your_iam_token
YANDEX_FOLDER_ID=your_folder_id
# YANDEXGPT_MODEL_URI=  # оставь пустым для auto

# Hugging Face
HUGGINGFACE_TOKEN=
HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_MODEL_SPACE=
HUGGINGFACE_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
HUGGINGFACE_LOCAL_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ──────────────────────────────────────────────────────────────
# 🦙 OLLAMA (локальный LLM)
# ──────────────────────────────────────────────────────────────

# URL Ollama сервера
OLLAMA_HOST=http://localhost:11434

# Основная модель (создай через: ollama create argos-core -f Argos.modelfile)
OLLAMA_MODEL=poilopr57/Argoss

# Таймаут запроса в секундах
OLLAMA_TIMEOUT=600

# Быстрая / облачная модели (опционально)
OLLAMA_FAST_MODEL=tinyllama
OLLAMA_CLOUD_MODEL=poilopr57/Argoss
OLLAMA_TIMEOUT_FAST=30
OLLAMA_TIMEOUT_SMART=120
OLLAMA_TIMEOUT_CLOUD=180

# ──────────────────────────────────────────────────────────────
# 🎙 ГОЛОС (TTS/STT локальный)
# ──────────────────────────────────────────────────────────────

# Включить голосовой вывод при старте (TTS)
ARGOS_VOICE_DEFAULT=off

# Whisper модель для распознавания речи: tiny / base / small / medium / large
WHISPER_MODEL=small

# Устройство для Whisper: cpu / cuda / rocm
WHISPER_DEVICE=cpu

# Тип вычислений Whisper: int8 / float16 / float32
WHISPER_COMPUTE_TYPE=int8

# ──────────────────────────────────────────────────────────────
# 🛡 БЕЗОПАСНОСТЬ
# ──────────────────────────────────────────────────────────────

# Роль доступа для терминальных команд: viewer / operator / admin / root
ARGOS_ROLE=admin

# Таймаут блокировки провайдера после ошибки (секунды, 60-3600)
ARGOS_PROVIDER_FAILURE_COOLDOWN=600
ARGOS_PROVIDER_COOLDOWN=60

# ──────────────────────────────────────────────────────────────
# 🧠 ПОВЕДЕНИЕ АРГОСА
# ──────────────────────────────────────────────────────────────

# Автоматический консенсус нескольких моделей (on/off)
ARGOS_AUTO_COLLAB=on

# Максимум моделей в консенсусе (2-4)
ARGOS_AUTO_COLLAB_MAX_MODELS=3

# Гомеостаз — автомониторинг нагрузки железа (on/off)
ARGOS_HOMEOSTASIS=on

# Любопытство — фоновые вопросы к себе (on/off)
ARGOS_CURIOSITY=on

# Самообеспечение — фоновое обучение из интернета (on/off)
ARGOS_SUSTAIN=on

# Быстрое отключение провайдеров без удаления ключей
ARGOS_DISABLE_GEMINI=0
ARGOS_DISABLE_GIGACHAT=0
ARGOS_DISABLE_KIMI=0
ARGOS_DISABLE_GRIST=0
ARGOS_ENABLE_IOT=1

# Уровень логов: DEBUG / INFO / WARNING / ERROR
ARGOS_LOG_LEVEL=INFO

# Файл debug-лога (опционально)
# ARGOS_DEBUG_LOG_FILE=logs/argos_debug.log

# ──────────────────────────────────────────────────────────────
# 📡 ПОДКЛЮЧЕНИЯ
# ──────────────────────────────────────────────────────────────

# MQTT (для IoT/Zigbee)
MQTT_HOST=localhost
MQTT_PORT=1883

# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=

# IBM Cloud Object Storage (опционально)
# IBM_COS_ENDPOINT=
# IBM_COS_API_KEY=
# IBM_COS_BUCKET=

# IBM Quantum
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_CHANNEL=ibm_quantum_platform

# ──────────────────────────────────────────────────────────────
# 🔧 GPU / NeuralSwarm
# ──────────────────────────────────────────────────────────────

# Индексы GPU для NeuralSwarm (AMD ROCm / NVIDIA CUDA)
# RX 580 (мозг, тяжёлые задачи)
NEURAL_SWARM_BRAIN_GPU=0

# RX 560 (рефлексы, Vision, GUI)
NEURAL_SWARM_REFLEX_GPU=1

# Vega / Reflex routing (Windows/AMD)
ARGOS_GPU_VEGA11=2
OLLAMA_REFLEX_HOST=http://localhost:11435
OLLAMA_REFLEX_MODEL=phi3:mini
OLLAMA_REFLEX_GPU=1
OLLAMA_VEGA_HOST=http://localhost:11436
OLLAMA_VEGA_MODEL=tinyllama

# ──────────────────────────────────────────────────────────────
# 📦 APK СБОРКА
# ──────────────────────────────────────────────────────────────

# Команда сборки APK (buildozer, gradle и т.д.)
# ARGOS_APK_BUILD_CMD=buildozer -v android debug

# ──────────────────────────────────────────────────────────────
# 🧬 ЭВОЛЮЦИЯ МОДЕЛИ (OllamaTrainer)
# ──────────────────────────────────────────────────────────────

# Имя развиваемой модели (должна быть создана в Ollama)
OLLAMA_TRAINER_MODEL=poilopr57/Argoss

# Базовая модель для Modelfile (должна быть установлена)
# ollama pull llama3.1
OLLAMA_TRAINER_BASE=llama3.1

# Минимум диалогов для старта эволюции
OLLAMA_TRAINER_MIN_TURNS=20

# Авто-эволюция каждые N диалогов (0 = выключено)
OLLAMA_TRAINER_AUTO_EVERY=50

# Максимум примеров диалогов в Modelfile
OLLAMA_TRAINER_MAX_EXAMPLES=30

# Векторный прогрев памяти
ARGOS_VECTOR_WARMUP_MODE=async
ARGOS_WARMUP_FACT_LIMIT=120
ARGOS_WARMUP_NOTE_LIMIT=60

# ──────────────────────────────────────────────────────────────
# 🧬 РАЗВИТИЕ МОДЕЛИ ARGOSS
# ──────────────────────────────────────────────────────────────

# Минимум диалогов для LoRA файнтюна (default: 50)
ARGOSS_FINETUNE_MIN_SAMPLES=50

# Минимальный рейтинг диалога для обучающего датасета (0.0–1.0, default: 0.6)
ARGOSS_MIN_QUALITY=0.6

# Авто-эволюция системного промпта каждые N диалогов (default: 20)
ARGOSS_EVOLVE_EVERY_N=20

# ──────────────────────────────────────────────────────────────
# 🟠 ORANGE PI ONE — АППАРАТНЫЙ МОСТ
# ──────────────────────────────────────────────────────────────

# GPIO бэкенд: auto / opi / gpiod / sysfs
OPI_GPIO_BACKEND=auto

# I2C шина (0 = /dev/i2c-0, пины 3/5; 1 = /dev/i2c-1, пины 27/28)
OPI_I2C_BUS=0

# UART порт и скорость
OPI_UART_PORT=/dev/ttyS1
OPI_UART_BAUD=9600

# RS-485 / Modbus RTU порт и скорость
OPI_RS485_PORT=/dev/ttyS2
OPI_RS485_BAUD=9600

# 1-Wire путь (DS18B20 датчики температуры)
OPI_1WIRE_PATH=/sys/bus/w1/devices

# ──────────────────────────────────────────────────────────────
# 🪟 WINDOWS-СПЕЦИФИЧНЫЕ НАСТРОЙКИ
# ──────────────────────────────────────────────────────────────

# Пути на Windows используют обратные слеши — Python Path() обрабатывает автоматически
# Примеры абсолютных путей для Windows:
# OLLAMA_HOST=http://localhost:11434
# ARGOS_APK_BUILD_CMD=buildozer -v android debug

# ffmpeg на Windows (нужен для голосовых ответов):
# Скачать: https://www.gyan.dev/ffmpeg/builds/
# Добавить в PATH: C:\ffmpeg\bin
# Проверить: ffmpeg -version

# Whisper на Windows (нужен GPU или CPU):
# pip install faster-whisper
# Для GPU: установи CUDA Toolkit https://developer.nvidia.com/cuda-downloads

# Orange Pi One на Windows — подключение через USB Serial:
# OPI_RS485_PORT=COM3        (вместо /dev/ttyUSB0)
# OPI_UART_PORT=COM4         (вместо /dev/ttyS3)

# Автозапуск:
# python argos_service.py bat     — добавить в Startup папку
# python argos_service.py install — установить как сервис (нужен NSSM)

# Windows PowerShell bridge
ARGOS_WIN_BRIDGE=on
ARGOS_WIN_BRIDGE_URL=http://localhost:5000/exec
ARGOS_WIN_BRIDGE_PORT=5000
ARGOS_BRIDGE_TOKEN=Generation_2026

# SMTP / Email
SMTP_PROVIDER=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# Legacy aliases for EmailBridge
ARGOS_EMAIL_USERNAME=
ARGOS_EMAIL_PASSWORD=
ARGOS_EMAIL_SMTP_HOST=
ARGOS_EMAIL_SMTP_PORT=
ARGOS_EMAIL_IMAP_HOST=

# ──────────────────────────────────────────────────────────────
# 🌐 CONTENT FETCHER / WHITELIST
# ──────────────────────────────────────────────────────────────

# Режим фетчера:
# 0 = safe (только разрешённые домены)
# 1 = free (полная свобода)
CONTENT_ALLOW_ALL=0

# Локальный REST API для dashboard кнопок
CONTENT_API_PORT=5050

# Список доменов через запятую (используется safe-режимом)
ALLOWED_DOMAINS=unsplash.com,images.unsplash.com,api.unsplash.com,pexels.com,images.pexels.com,openverse.engineering,commons.wikimedia.org,freemusicarchive.org,jamendo.com,raw.githubusercontent.com,githubusercontent.com,gutenberg.org,samplefiles.org,picsum.photos,loremflickr.com

# ──────────────────────────────────────────────────────────────
# 🧰 ПРОШИВКИ / COLIBRI OS
# ──────────────────────────────────────────────────────────────

# PlatformIO environment для ESP32
FIRMWARE_ESP32_ENV=esp32dev

# Arduino FQBN для ESP8266
FIRMWARE_ESP8266_FQBN=esp8266:esp8266:nodemcuv2

# Порт прошивки (опционально): COM3 / /dev/ttyUSB0
FIRMWARE_UPLOAD_PORT=

# Commit KolibriOS для сборки ISO
COLIBRI_COMMIT=a7706a062a449ae56751ac980603b9ead

# Единая строка Redis подключения (опционально, приоритетнее REDIS_HOST/PORT)
REDIS_URL=
